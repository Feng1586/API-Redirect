# ============================================================
# LLM Proxy 环境变量配置文件
# ============================================================
# 配置说明：
# 1. 本文件为示例文件，复制为 .env 使用
# 2. 环境变量优先级高于 config.yaml
# 3. 变量名使用双下划线 "__" 分隔嵌套配置（如 APP__PORT）
# 4. 生产环境请务必修改所有密码和密钥相关配置
# ============================================================

# ------------------------------------------------------------
# 应用配置 (app)
# ------------------------------------------------------------
# 服务监听端口
APP__PORT=8000

# 调试模式：true 启用详细日志，false 关闭
APP__DEBUG=false

# 会话加密密钥（至少32位随机字符串）
APP__SECRET_KEY=your-secret-key-change-me-in-production

# JWT 签名密钥（至少32位随机字符串）
APP__JWT_SECRET=your-jwt-secret-change-me-in-production


# ------------------------------------------------------------
# 数据库配置 (database)
# ------------------------------------------------------------
# MySQL 主机地址
DATABASE__HOST=localhost

# MySQL 端口
DATABASE__PORT=3306

# 数据库用户名
DATABASE__USERNAME=root

# 数据库密码
DATABASE__PASSWORD=your-password-here

# 数据库名称
DATABASE__NAME=llm_proxy


# ------------------------------------------------------------
# Redis 配置 (redis)
# ------------------------------------------------------------
# Redis 主机地址
REDIS__HOST=localhost

# Redis 端口
REDIS__PORT=6379

# Redis 数据库编号（0-15）
REDIS__DB=0

# Redis 密码（无密码则留空）
REDIS__PASSWORD=


# ------------------------------------------------------------
# 邮件配置 (email)
# ------------------------------------------------------------
# Resend API Key（用于发送邮件）
# 获取地址：https://resend.com/api-keys
EMAIL__RESEND_API_KEY=

# 发件人邮箱地址
EMAIL__FROM_EMAIL=noreply@yourdomain.com

# 发件人名称
EMAIL__FROM_NAME=LLM Proxy


# ------------------------------------------------------------
# 上游服务配置 (upstream)
# ------------------------------------------------------------
# 上游 API 基础地址（末尾不要加斜杠）
UPSTREAM__BASE_URL=https://api.apimart.ai/v1

# 上游 API Key（强烈建议通过环境变量设置，不要写在文件中）
UPSTREAM__API_KEY=

# 请求超时时间（秒）
UPSTREAM__TIMEOUT=120

# Gemini 专用基础地址（如果 Gemini 使用不同端点）
UPSTREAM__GEMINI_BASE_URL=


# ------------------------------------------------------------
# 计费配置 (billing)
# ------------------------------------------------------------
# 最小充值金额（美元）
BILLING__MIN_CHARGE=0.01

# 新用户赠送金额（美元，0 表示不赠送）
BILLING__FREE_BALANCE=0.00


# ------------------------------------------------------------
# 会话配置 (session)
# ------------------------------------------------------------
# 会话有效期（秒），86400 = 24小时
SESSION__TTL=86400

# Cookie 名称
SESSION__COOKIE_NAME=llm_session

# Cookie 安全属性（生产环境必须为 true）
SESSION__COOKIE_SECURE=true

# Cookie HttpOnly 属性（建议保持 true）
SESSION__COOKIE_HTTPONLY=true

# Cookie SameSite 属性（none: 允许跨域，lax: 默认）
SESSION__COOKIE_SAMESITE=none


# ------------------------------------------------------------
# 限流配置 (rate_limit)
# ------------------------------------------------------------
# 每分钟允许发送验证码的最大次数
RATE_LIMIT__VERIFY_CODE_PER_MINUTE=1

# 登录失败最大尝试次数
RATE_LIMIT__LOGIN_MAX_ATTEMPTS=5

# 登录锁定时长（分钟）
RATE_LIMIT__LOGIN_LOCKOUT_MINUTES=15


# ------------------------------------------------------------
# PayPal 支付配置 (paypal)
# ------------------------------------------------------------
# PayPal API 基础地址
PAYPAL__PAYPAL_BASE_URL=https://api-m.sandbox.paypal.com

# PayPal Client ID
PAYPAL__CLIENT_ID=

# PayPal Client Secret
PAYPAL__CLIENT_SECRET=

# 代理服务器地址（如不需要则留空）
# 格式：http://user:password@proxyhost:port
PAYPAL__PROXY=